{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'Building BlackRoad OS services...'"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": [
    {
      "name": "auth-api",
      "startCommand": "python3 blackroad-auth-system.py",
      "healthcheckPath": "/api/health",
      "healthcheckTimeout": 300,
      "env": {
        "PORT": "11000",
        "PYTHONUNBUFFERED": "1",
        "BLACKROAD_ENV": "production"
      }
    },
    {
      "name": "event-bus",
      "startCommand": "python3 blackroad-event-bus.py",
      "healthcheckPath": "/api/health",
      "healthcheckTimeout": 300,
      "env": {
        "PORT": "9800",
        "PYTHONUNBUFFERED": "1",
        "BLACKROAD_ENV": "production"
      }
    },
    {
      "name": "service-registry",
      "startCommand": "python3 blackroad-service-registry.py",
      "healthcheckPath": "/api/health",
      "healthcheckTimeout": 300,
      "env": {
        "PORT": "9900",
        "PYTHONUNBUFFERED": "1",
        "BLACKROAD_ENV": "production"
      }
    },
    {
      "name": "operator",
      "startCommand": "python3 operator_http.py",
      "healthcheckPath": "/status",
      "healthcheckTimeout": 300,
      "env": {
        "PORT": "8000",
        "PYTHONUNBUFFERED": "1",
        "BLACKROAD_ENV": "production"
      }
    },
    {
      "name": "agent-orchestrator",
      "startCommand": "python3 blackroad-agent-orchestrator-v2.py",
      "healthcheckPath": "/api/health",
