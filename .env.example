# BlackRoad OS Core — Environment Configuration Template
# Copy this file to .env and fill in your values

# ========================================
# Application Settings
# ========================================

# Environment: development | staging | production
NODE_ENV=development

# HTTP port (Railway will override this in production)
PORT=3000

# ========================================
# Database Configuration
# ========================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Required in staging/production, optional in development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blackroad_core_dev

# ========================================
# Cache Configuration
# ========================================

# Redis connection string (optional)
# Format: redis://user:password@host:port
# Leave empty to disable Redis caching
REDIS_URL=

# ========================================
# API Configuration
# ========================================

# Public-facing base URL for this API
# Required in staging/production
# Examples:
#   - development: http://localhost:3000
#   - staging: https://staging.core.blackroad.systems
#   - production: https://core.blackroad.systems
PUBLIC_BASE_URL=http://localhost:3000
