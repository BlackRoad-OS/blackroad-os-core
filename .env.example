# ----------------------------------------------------------
# Converter API Key (REQUIRED for all contributor access)
# ----------------------------------------------------------
BLACKROAD_CONVERTER_API_KEY=

# ----------------------------------------------------------
# Vendor Gateway (OATH layer — routes all AI calls through
# BlackRoad infrastructure via Tailscale / Cloudflare)
# ----------------------------------------------------------
BLACKROAD_GATEWAY_URL=http://localhost:10200
BLACKROAD_OPERATOR=blackboxprogramming
BLACKROAD_TAILSCALE_HOST=

# ----------------------------------------------------------
# Cloudflare
# ----------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=848cf0b18d51e0170e0d1537aec3505a

# ----------------------------------------------------------
# Railway
# ----------------------------------------------------------
RAILWAY_TOKEN=

# ----------------------------------------------------------
# Stripe (payment processing)
# ----------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------
# Clerk (authentication)
# ----------------------------------------------------------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ----------------------------------------------------------
# AI APIs (routed through BlackRoad Gateway — not direct)
# ----------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
DATABASE_URL=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ----------------------------------------------------------
# Service Mesh
# ----------------------------------------------------------
SERVICE_REGISTRY_URL=https://api.blackroad.io/registry
SERVICE_NAME=blackroad-os-core
SERVICE_ORG=BlackRoad-OS
