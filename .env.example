# BlackRoad OS Core - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER
# =============================================================================
PORT=8080

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/blackroad_os"

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
# Personal Access Token or GitHub App token
# Required scopes: repo, read:org
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=""

# Optional: For GitHub Enterprise Server
# GITHUB_API_URL="https://github.mycompany.com/api/v3"

# =============================================================================
# CLOUDFLARE INTEGRATION
# =============================================================================
# API Token with Zone:Read, DNS:Read, DNS:Edit permissions
# Get one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""

# Account ID (required for Tunnels/Pages)
# Find it in your Cloudflare dashboard URL or overview page
CLOUDFLARE_ACCOUNT_ID=""

# Optional: Tunnel configuration
# CLOUDFLARE_TUNNEL_ID=""
# CLOUDFLARE_TUNNEL_NAME=""

# =============================================================================
# RAILWAY INTEGRATION
# =============================================================================
# API Token from Railway dashboard
# Get one at: https://railway.app/account/tokens
RAILWAY_TOKEN=""

# Optional: Team ID for team projects
# RAILWAY_TEAM_ID=""

# =============================================================================
# VERCEL INTEGRATION
# =============================================================================
# API Token from Vercel dashboard
# Get one at: https://vercel.com/account/tokens
VERCEL_TOKEN=""

# Optional: Team ID for team deployments
# VERCEL_TEAM_ID=""

# =============================================================================
# DIGITALOCEAN INTEGRATION
# =============================================================================
# API Token from DigitalOcean dashboard
# Get one at: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=""

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================
# Get these from your Clerk dashboard
# https://dashboard.clerk.com
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
# Get these from your Stripe dashboard
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# =============================================================================
# NOTION INTEGRATION
# =============================================================================
# Internal integration token from Notion
# Get one at: https://www.notion.so/my-integrations
NOTION_TOKEN=""

# =============================================================================
# ASANA INTEGRATION
# =============================================================================
# Personal Access Token from Asana
# Get one at: https://app.asana.com/0/developer-console
ASANA_TOKEN=""

# =============================================================================
# HUGGING FACE INTEGRATION
# =============================================================================
# Access token from Hugging Face
# Get one at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=""
# Alternative env var name
# HF_TOKEN=""

# =============================================================================
# TUNNEL INTEGRATIONS
# =============================================================================
# ngrok authentication token
# Get one at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=""
# Optional: ngrok region (us, eu, ap, au, sa, jp, in)
# NGROK_REGION="us"

# Tailscale authentication key (optional)
# Get one at: https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTHKEY=""

# =============================================================================
# RASPBERRY PI FLEET (for deploy-to-pis workflow)
# =============================================================================
# SSH keys and IPs for Pi deployments
# PI_SSH_KEY=""
# PI_LUCIDIA_IP="192.168.4.38"
# PI_BLACKROAD_IP="192.168.4.64"
# PI_MYSTERY_IP="192.168.4.49"

# =============================================================================
# DIGITALOCEAN DROPLET (for deploy-droplet workflow)
# =============================================================================
# DROPLET_IP=""
# DROPLET_SSH_KEY=""

# =============================================================================
# OPTIONAL: APPLICATION CONFIG
# =============================================================================
# NODE_ENV=development
# LOG_LEVEL=debug
