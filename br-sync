#!/usr/bin/env python3
"""BlackRoad Real-Time Sync CLI - No more push/pull"""
import sys, os, subprocess

SERVER_URL = os.getenv('BLACKROAD_SYNC_SERVER', 'http://localhost:9950')

def cmd_start():
    subprocess.run(['python3', 'blackroad-realtime-dev.py'])

def cmd_status():
    import requests
    try:
        r = requests.get(f"{SERVER_URL}/api/presence")
        data = r.json()
        print(f"\n{'='*60}")
        print(f"📊 Real-Time Sync Status")
        print(f"{'='*60}")
        print(f"Users Online: {data['total_users']}")
        print(f"Active Files: {data['total_files']}")
        if data['users']:
            print("\n👥 Active:")
            for u in data['users']:
                print(f"  • {u['user_id']} - {len(u['files'])} files")
                for f in u['files']: print(f"    └─ {f}")
        print(f"{'='*60}\n")
    except: print("❌ Server not running. Start with: br-sync start")

if __name__ == '__main__':
    cmd = sys.argv[1] if len(sys.argv) > 1 else 'help'
    if cmd == 'start': cmd_start()
    elif cmd == 'status': cmd_status()
    else: print("Usage: br-sync [start|status]")
