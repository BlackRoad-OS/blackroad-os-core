{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "apps/**/.next/**", "apps/**/src-tauri/target/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "postbuild": {
      "dependsOn": ["build"],
      "outputs": ["apps/web/public/sig.beacon.json"]
    }
  }
}
