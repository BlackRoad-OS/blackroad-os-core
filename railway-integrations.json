{
  "name": "blackroad-integrations-hub",
  "runtime": "python",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn blackroad-integrations-hub:app --host 0.0.0.0 --port ${PORT:-9500}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  },
  "domains": [
    {
      "domain": "integrations.blackroad.io"
    }
  ],
  "envVars": {
    "SLACK_ACCESS_TOKEN": "${SLACK_ACCESS_TOKEN}",
    "NOTION_TOKEN": "${NOTION_TOKEN}",
    "LINEAR_API_KEY": "${LINEAR_API_KEY}",
    "ASANA_API_KEY": "${ASANA_API_KEY}",
    "TRELLO_API_KEY": "${TRELLO_API_KEY}",
    "TRELLO_TOKEN": "${TRELLO_TOKEN}",
    "JIRA_API_TOKEN": "${JIRA_API_TOKEN}",
    "JIRA_SITE_URL": "${JIRA_SITE_URL}",
    "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}",
    "GITHUB_TOKEN": "${GITHUB_TOKEN}",
    "GOOGLE_DRIVE_CREDENTIALS": "${GOOGLE_DRIVE_CREDENTIALS}",
    "TEAMS_WEBHOOK_URL": "${TEAMS_WEBHOOK_URL}",
    "ZOOM_API_KEY": "${ZOOM_API_KEY}",
    "ZOOM_API_SECRET": "${ZOOM_API_SECRET}",
    "AIRTABLE_API_KEY": "${AIRTABLE_API_KEY}",
    "SALESFORCE_ACCESS_TOKEN": "${SALESFORCE_ACCESS_TOKEN}",
    "SALESFORCE_INSTANCE_URL": "${SALESFORCE_INSTANCE_URL}",
    "HUBSPOT_API_KEY": "${HUBSPOT_API_KEY}",
    "ZENDESK_API_TOKEN": "${ZENDESK_API_TOKEN}",
    "ZENDESK_DOMAIN": "${ZENDESK_DOMAIN}",
    "PORT": "9510"
  }
}
